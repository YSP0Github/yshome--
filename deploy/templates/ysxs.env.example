# ===== 与当前已跑通服务器一致的基础项 =====
YSXS_ENV=production
YSXS_URL_PREFIX=/YSXS
YSXS_DATABASE_URI=sqlite:////home/YSP/var/ysxs/ysxs.db
YSXS_UPLOAD_DIR=/home/YSP/var/ysxs/uploads
YSXS_ALLOWED_ORIGIN=https://yshome.top
YSXS_SECRET_KEY=__GENERATE_ME__

# ===== 可选：AI / 晨报 =====
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_WIRE_API=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_WIRE_API=
MIMO_API_KEY=
MIMO_OPENAI_BASE_URL=
MIMO_OPENAI_WIRE_API=
MIMO_ANTHROPIC_BASE_URL=
MIMO_ANTHROPIC_MODEL=
MIMO_ANTHROPIC_WIRE_API=
YSXS_OPENAI_API_KEY=
YSXS_OPENAI_BASE_URL=
YSXS_AI_MODEL=
YSXS_AI_WIRE_API=
NASA_ADS_API_TOKEN=
ADS_API_TOKEN=
YSXS_KINDLE_EMAIL=

# ===== 可选：自定义智能预设（供“智能管理系统”单选）=====
# 命名规则：
#   YSXS_AI_PRESET_<序号>_KEY=内部键名（建议英文/下划线）
#   YSXS_AI_PRESET_<序号>_LABEL=前端显示名称
#   YSXS_AI_PRESET_<序号>_BASE_URL=该模型对应的接口根地址
#   YSXS_AI_PRESET_<序号>_MODEL=模型名
#   YSXS_AI_PRESET_<序号>_WIRE_API=responses / chat_completions / anthropic_messages
#   YSXS_AI_PRESET_<序号>_API_KEY_ENV=该预设应优先读取的 API Key 环境变量名
#
# 当前支持 1~12 号预设。不同预设可以配置不同 BASE_URL。
#
# 示例 1：OpenAI
# YSXS_AI_PRESET_1_KEY=openai_gpt54
# YSXS_AI_PRESET_1_LABEL=OpenAI · GPT-5.4
# YSXS_AI_PRESET_1_BASE_URL=https://api.openai.com/v1
# YSXS_AI_PRESET_1_MODEL=gpt-5.4
# YSXS_AI_PRESET_1_WIRE_API=responses
# YSXS_AI_PRESET_1_API_KEY_ENV=OPENAI_API_KEY
#
# 示例 2：MiMo Anthropic 兼容
# YSXS_AI_PRESET_2_KEY=mimo_pro
# YSXS_AI_PRESET_2_LABEL=MiMo Pro · Anthropic
# YSXS_AI_PRESET_2_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic/v1
# YSXS_AI_PRESET_2_MODEL=mimo-v2.5-pro
# YSXS_AI_PRESET_2_WIRE_API=anthropic_messages
# YSXS_AI_PRESET_2_API_KEY_ENV=MIMO_API_KEY

# ===== 可选：邮件 =====
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# ===== 可选：性能 / 限流 =====
YSXS_DOCS_PER_PAGE=12
YSXS_MAX_BANDWIDTH_BPS=0
YSXS_LITERATURE_SEARCH_JOB_TTL_SECONDS=1800
YSXS_RESEARCH_OVERVIEW_JOB_TTL_SECONDS=1800
YSXS_RESEARCH_OVERVIEW_AI_TIMEOUT=120

# ===== SeisRT / 其他扩展配置（按需填写） =====
YSXS_SEISRT_VAR_DIR=/home/YSP/var/seisrt
YSXS_AMAP_WEB_KEY=

# ===== 可选：数据库异地备份 =====
BACKUP_REMOTE_HOST=100.78.235.109
BACKUP_REMOTE_PORT=22
BACKUP_REMOTE_USER=
BACKUP_REMOTE_DIR=/G:/GitHub/个人主页/var/yun_data
BACKUP_REMOTE_PASSWORD=
BACKUP_LOCAL_DIR=
BACKUP_LOCAL_KEEP_DAYS=30
BACKUP_ALERT_EMAIL=yusp519@qq.com
