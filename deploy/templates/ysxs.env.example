# ===== 必填/强烈建议 =====
YSXS_ENV=production
YSXS_URL_PREFIX=/YSXS
YSXS_SECRET_KEY=__GENERATE_ME__
YSXS_DATABASE_URI=sqlite:////opt/yshome/var/ysxs/ysxs.db
YSXS_UPLOAD_DIR=/opt/yshome/var/ysxs/uploads
YSXS_ALLOWED_ORIGIN=https://example.com
YSXS_PORT=5050

# ===== 可选：AI/晨报相关 =====
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_WIRE_API=
YSXS_OPENAI_API_KEY=
YSXS_OPENAI_BASE_URL=
YSXS_AI_MODEL=
YSXS_AI_WIRE_API=
NASA_ADS_API_TOKEN=
ADS_API_TOKEN=
YSXS_KINDLE_EMAIL=

# ===== 可选：邮件 =====
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# ===== 可选：性能/限流 =====
YSXS_DOCS_PER_PAGE=12
YSXS_MAX_BANDWIDTH_BPS=0
YSXS_LITERATURE_SEARCH_JOB_TTL_SECONDS=1800
YSXS_RESEARCH_OVERVIEW_JOB_TTL_SECONDS=1800
YSXS_RESEARCH_OVERVIEW_AI_TIMEOUT=120

# ===== 可选：数据库异地备份 =====
BACKUP_REMOTE_HOST=100.78.235.109
BACKUP_REMOTE_PORT=22
BACKUP_REMOTE_USER=
# Windows OpenSSH 常见写法示例：/G:/GitHub/个人主页/var/yun_data
BACKUP_REMOTE_DIR=/G:/GitHub/个人主页/var/yun_data
# 强烈建议使用 SSH 密钥；如必须用密码，可填写并自行安装 sshpass
BACKUP_REMOTE_PASSWORD=
BACKUP_LOCAL_DIR=
BACKUP_LOCAL_KEEP_DAYS=30
BACKUP_ALERT_EMAIL=yusp519@qq.com
